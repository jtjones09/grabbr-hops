// hops — the GUI surface. Composes the design tokens (theme.slint) and the
// atoms (widgets.slint) into the control panel. Rust sets Theme.index, the status
// fields, the two lists, and the live pairing-fp; the callbacks send FrontendRequests.

import { Theme, Type, Space, Radius, Motion, Size } from "theme.slint";
import { Card, Separator, Dot, Chip, StatChip, SectionTitle, PillButton, TextField, Toggle } from "widgets.slint";
import { OnboardingWindow } from "onboarding.slint";
import { LayoutCanvas, CanvasBox } from "layout_canvas.slint";
import { HopsTray } from "tray.slint";
import { ScrollView } from "std-widgets.slint";

// re-export so Rust can select the active palette via `ui.global::<Theme>()`.
// OnboardingWindow/CanvasBox/HopsTray are re-exported here too (not compiled as
// their own separate slint_build entry points) so they share this SAME generated
// `Theme`/`ThemeColors` Rust type — two independent `slint_build::compile()`
// calls over files that both import theme.slint would otherwise produce two
// nominally distinct types.
export { Theme, OnboardingWindow, CanvasBox, HopsTray }

export struct DeviceRow {
    handle: string,  // ClientHandle (u64 as text — Slint int is only i32)
    name: string,    // hostname
    addr: string,    // "ip:port" or "unresolved"
    pos: string,     // "left" / "right" / …
    active: bool,    // capture is routed to this device
    alive: bool,     // device is reachable
}

export struct TrustedRow {
    name: string,
    fp: string,      // short fingerprint (display)
    fp-full: string, // full fingerprint (for requests)
    online: bool,
}

export component AppWindow inherits Window {
    title: "hops";
    default-font-family: Type.sans;
    default-font-size: Type.body;
    // Fixed-size control panel — non-resizable, like Shottr / CleanShot /
    // Synergy settings (a KVM control surface is all settings, never a canvas
    // you drag-resize). min == max == preferred locks the frame, so it can
    // neither be resized nor auto-collapse to the titlebar; the device/trusted
    // lists SCROLL within it (ScrollView below) so any machine count fits.
    // Rust also asserts this size on show (show_app_window) as belt-and-braces.
    preferred-width: 560px;
    preferred-height: 690px;
    min-width: 560px;
    max-width: 560px;
    min-height: 690px;
    max-height: 690px;
    background: Theme.c.background;

    in property <bool> connected: false;
    in property <string> capture: "—";
    in property <string> emulation: "—";
    in property <string> port: "—";
    in property <string> fingerprint: "—";
    in property <[DeviceRow]> devices: [];
    in property <[TrustedRow]> trusted: [];
    in property <string> pairing-fp: "";

    property <string> confirm-revoke-fp: "";
    // `in-out` so the render_png self-review harness can open it for a look.
    in-out property <string> confirm-delete-handle: "";
    // handle of the device being renamed ("" = none). The rename FIELD lives
    // in a single shared panel below the list, NOT inline per-row — `devices`
    // is a brand-new VecModel every ~250ms poll tick, so a TextField inside
    // the `for` loop would have its in-progress typing wiped out on the next
    // tick along with the rest of that row's instance. A property compared
    // against `d.handle` (like this one, and confirm-revoke-fp/
    // confirm-delete-handle above) is safe because it lives on `root`, outside
    // the loop, and is just re-read fresh each time a row re-renders.
    // `in-out` so the render_png self-review harness can open it for a look.
    in-out property <string> editing-device: "";
    // `in-out` (not a plain internal property) so the render_png self-review
    // harness can open these overlays from outside for a look — not used by the
    // real app's Rust side, which only ever reads them indirectly via clicks.
    in-out property <bool> show-settings: false;
    in-out property <bool> show-add-device: false;
    property <string> add-device-position: "left";
    // `in-out`: Rust sets both together, once, when the canvas opens — NOT
    // re-pushed by the poll timer (see layout_canvas.slint's header note on
    // why a drag would otherwise get fought by the next live update).
    in-out property <bool> show-layout-canvas: false;
    in-out property <[CanvasBox]> canvas-boxes: [];

    callback enable-input();
    callback activate-device(string /* handle */, bool /* active */);
    callback reposition-device(string /* handle */, string /* new position */);
    callback rename-device(string /* handle */, string /* new name */);
    callback delete-device(string /* handle */);
    callback revoke(string /* full fingerprint */);
    callback approve-pairing(string /* name */, string /* full fingerprint */);
    callback deny-pairing(string /* full fingerprint */);
    callback set-theme(int /* palette index */);
    callback create-device(string /* name */, string /* port */, string /* position */);
    callback switch-interface();
    callback open-layout-canvas();
    callback update-device-geometry(string /* handle */, float /* x */, float /* y */);

    VerticalLayout {
        padding: Space.xxl;
        spacing: Space.lg;

        // --- header: wordmark + inline connection ------------------------------
        HorizontalLayout {
            alignment: space-between;
            Text {
                text: "hops";
                font-size: Type.heading;
                font-weight: Type.bold;
                color: Theme.c.foreground;
                vertical-alignment: center;
            }
            HorizontalLayout {
                spacing: Space.md;
                HorizontalLayout {
                    spacing: Space.sm;
                    VerticalLayout {
                        alignment: center;
                        Dot { tint: root.connected ? Theme.c.success : Theme.c.warn; }
                    }
                    Text {
                        text: root.connected ? "connected" : "connecting";
                        color: root.connected ? Theme.c.success : Theme.c.warn;
                        font-size: Type.small;
                        font-weight: Type.semibold;
                        vertical-alignment: center;
                    }
                }
                PillButton {
                    text: "settings";
                    ghost: true;
                    clicked => { root.show-settings = true; }
                }
            }
        }

        // --- status line (plain inline, no boxes) ------------------------------
        HorizontalLayout {
            spacing: Space.lg;
            alignment: start;
            HorizontalLayout {
                spacing: 5px;
                Text { text: "capture"; color: Theme.c.muted; font-size: Type.small; }
                Text {
                    text: root.capture == "enabled" ? "on" : "off";
                    color: root.capture == "enabled" ? Theme.c.success : Theme.c.muted;
                    font-size: Type.small;
                    font-weight: Type.semibold;
                }
            }
            HorizontalLayout {
                spacing: 5px;
                Text { text: "emulation"; color: Theme.c.muted; font-size: Type.small; }
                Text {
                    text: root.emulation == "enabled" ? "on" : "off";
                    color: root.emulation == "enabled" ? Theme.c.success : Theme.c.muted;
                    font-size: Type.small;
                    font-weight: Type.semibold;
                }
            }
            HorizontalLayout {
                spacing: 5px;
                Text { text: "port"; color: Theme.c.muted; font-size: Type.small; }
                Text {
                    text: root.port;
                    color: Theme.c.foreground;
                    font-family: Type.mono;
                    font-size: Type.small;
                    letter-spacing: Type.mono-tracking;
                }
            }
            if root.capture != "enabled" || root.emulation != "enabled": PillButton {
                text: "enable input";
                primary: true;
                clicked => { root.enable-input(); }
            }
        }

        // Everything between the fixed header/status and the fixed footer
        // scrolls, so the window stays a fixed size no matter how many
        // devices are paired (few -> some slack above the footer; many ->
        // it scrolls). See the Window size note above.
        ScrollView {
            vertical-stretch: 1;
            VerticalLayout {
                spacing: Space.lg;
                alignment: start;
                // --- pairing request (Windows wants to pair with this Mac) -------------
                if root.pairing-fp != "": Rectangle {
                    vertical-stretch: 0;
                    background: Theme.c.warn.transparentize(0.9);
                    border-radius: Radius.lg;
                    border-width: 1px;
                    border-color: Theme.c.warn.transparentize(0.55);
                    VerticalLayout {
                        padding: Space.md;
                        spacing: Space.sm;
                        Text {
                            text: "pairing request";
                            color: Theme.c.warn;
                            font-size: Type.small;
                            font-weight: Type.semibold;
                        }
                        Text {
                            text: root.pairing-fp;
                            color: Theme.c.muted;
                            font-family: Type.mono;
                            font-size: Type.caption;
                            letter-spacing: Type.mono-tracking;
                            overflow: elide;
                        }
                        HorizontalLayout {
                            spacing: Space.sm;
                            name := TextField {
                                placeholder: "name this device";
                                horizontal-stretch: 1;
                                accepted => {
                                    root.approve-pairing(self.text, root.pairing-fp);
                                    self.text = "";
                                }
                            }
                            PillButton {
                                text: "trust & name";
                                primary: true;
                                clicked => {
                                    root.approve-pairing(name.text, root.pairing-fp);
                                    name.text = "";
                                }
                            }
                            PillButton {
                                text: "deny";
                                clicked => { root.deny-pairing(root.pairing-fp); }
                            }
                        }
                    }
                }

                // --- devices ------------------------------------------------------------
                HorizontalLayout {
                    alignment: space-between;
                    SectionTitle { text: "devices — cross to"; color: Theme.c.accent; }
                    HorizontalLayout {
                        spacing: Space.sm;
                        PillButton {
                            text: "arrange";
                            ghost: true;
                            clicked => { root.open-layout-canvas(); }
                        }
                        PillButton {
                            text: root.show-add-device ? "cancel" : "+ add";
                            ghost: true;
                            clicked => { root.show-add-device = !root.show-add-device; }
                        }
                    }
                }
                if root.show-add-device: Rectangle {
                    vertical-stretch: 0;
                    background: Theme.c.surface;
                    border-radius: Radius.lg;
                    border-width: 1px;
                    border-color: Theme.c.border;
                    VerticalLayout {
                        padding: Space.md;
                        spacing: Space.sm;
                        HorizontalLayout {
                            spacing: Space.sm;
                            add-name := TextField {
                                placeholder: "name (e.g. studio-pc)";
                                horizontal-stretch: 2;
                            }
                            add-port := TextField {
                                placeholder: "4242";
                                horizontal-stretch: 1;
                            }
                        }
                        HorizontalLayout {
                            spacing: Space.sm;
                            Text {
                                text: "position";
                                color: Theme.c.muted;
                                font-size: Type.small;
                                vertical-alignment: center;
                            }
                            for p in ["left", "right", "top", "bottom"]: PillButton {
                                text: p;
                                primary: root.add-device-position == p;
                                clicked => { root.add-device-position = p; }
                            }
                        }
                        HorizontalLayout {
                            spacing: Space.sm;
                            PillButton {
                                text: "add device";
                                primary: true;
                                clicked => {
                                    root.create-device(add-name.text, add-port.text, root.add-device-position);
                                    add-name.text = "";
                                    add-port.text = "";
                                    root.add-device-position = "left";
                                    root.show-add-device = false;
                                }
                            }
                        }
                    }
                }
                Card {
                    vertical-stretch: 0;
                    VerticalLayout {
                        padding: Space.sm;
                        spacing: 2px;
                        if root.devices.length == 0: HorizontalLayout {
                            padding: Space.sm;
                            Text {
                                text: "no outgoing devices — this Mac only receives";
                                color: Theme.c.muted;
                                font-size: Type.small;
                            }
                        }
                        for d in root.devices: Rectangle {
                            height: 56px;
                            border-radius: Radius.md;
                            drow := TouchArea {}
                            background: drow.has-hover ? Theme.c.surface-raised : transparent;
                            animate background { duration: Motion.fast; }
                            HorizontalLayout {
                                padding-left: Space.md;
                                padding-right: Space.md;
                                spacing: Space.md;
                                VerticalLayout {
                                    alignment: center;
                                    Dot {
                                        tint: d.alive
                                            ? Theme.c.success
                                            : (d.active ? Theme.c.warn : Theme.c.muted);
                                    }
                                }
                                VerticalLayout {
                                    alignment: center;
                                    spacing: 2px;
                                    horizontal-stretch: 1;
                                    Text {
                                        text: d.name;
                                        color: Theme.c.foreground;
                                        font-weight: Type.medium;
                                        overflow: elide;
                                    }
                                    Text {
                                        text: d.addr;
                                        color: Theme.c.muted;
                                        font-family: Type.mono;
                                        font-size: Type.caption;
                                        letter-spacing: Type.mono-tracking;
                                        overflow: elide;
                                    }
                                }
                                VerticalLayout {
                                    alignment: center;
                                    Chip {
                                        text: d.pos;
                                        text-color: Theme.c.accent;
                                        fill: Theme.c.accent.transparentize(0.85);
                                        pos-ta := TouchArea {
                                            mouse-cursor: pointer;
                                            clicked => {
                                                root.reposition-device(d.handle, d.pos == "left" ? "right"
                                                    : d.pos == "right" ? "top"
                                                    : d.pos == "top" ? "bottom" : "left");
                                            }
                                        }
                                    }
                                }
                                VerticalLayout {
                                    alignment: center;
                                    Toggle {
                                        checked: d.active;
                                        toggled(v) => { root.activate-device(d.handle, v); }
                                    }
                                }
                                if root.confirm-delete-handle != d.handle: VerticalLayout {
                                    alignment: center;
                                    PillButton {
                                        text: "edit";
                                        ghost: true;
                                        clicked => { root.editing-device = root.editing-device == d.handle ? "" : d.handle; }
                                    }
                                }
                                if root.confirm-delete-handle != d.handle: VerticalLayout {
                                    alignment: center;
                                    PillButton {
                                        text: "delete";
                                        ghost: true;
                                        clicked => { root.confirm-delete-handle = d.handle; }
                                    }
                                }
                                if root.confirm-delete-handle == d.handle: VerticalLayout {
                                    alignment: center;
                                    Text {
                                        text: "delete?";
                                        color: Theme.c.muted;
                                        font-size: Type.small;
                                    }
                                }
                                if root.confirm-delete-handle == d.handle: VerticalLayout {
                                    alignment: center;
                                    PillButton {
                                        text: "yes";
                                        danger: true;
                                        clicked => {
                                            root.delete-device(d.handle);
                                            root.confirm-delete-handle = "";
                                            root.editing-device = "";
                                        }
                                    }
                                }
                                if root.confirm-delete-handle == d.handle: VerticalLayout {
                                    alignment: center;
                                    PillButton {
                                        text: "no";
                                        ghost: true;
                                        clicked => { root.confirm-delete-handle = ""; }
                                    }
                                }
                            }
                        }
                        if root.editing-device != "": Rectangle {
                            background: Theme.c.surface-raised;
                            border-radius: Radius.md;
                            VerticalLayout {
                                padding: Space.md;
                                spacing: Space.sm;
                                Text {
                                    text: "rename device";
                                    color: Theme.c.muted;
                                    font-size: Type.caption;
                                }
                                HorizontalLayout {
                                    spacing: Space.sm;
                                    rename-field := TextField {
                                        placeholder: "new name";
                                        horizontal-stretch: 1;
                                        accepted => {
                                            root.rename-device(root.editing-device, self.text);
                                            self.text = "";
                                            root.editing-device = "";
                                        }
                                    }
                                    PillButton {
                                        text: "save";
                                        primary: true;
                                        clicked => {
                                            root.rename-device(root.editing-device, rename-field.text);
                                            rename-field.text = "";
                                            root.editing-device = "";
                                        }
                                    }
                                    PillButton {
                                        text: "cancel";
                                        ghost: true;
                                        clicked => {
                                            rename-field.text = "";
                                            root.editing-device = "";
                                        }
                                    }
                                }
                            }
                        }
                    }
                }

                // --- trusted peers ------------------------------------------------------
                SectionTitle { text: "trusted devices"; color: Theme.c.accent; }
                Card {
                    vertical-stretch: 0;
                    VerticalLayout {
                        padding: Space.sm;
                        spacing: 2px;
                        if root.trusted.length == 0: HorizontalLayout {
                            padding: Space.sm;
                            Text {
                                text: "no trusted devices yet";
                                color: Theme.c.muted;
                                font-size: Type.small;
                            }
                        }
                        for t in root.trusted: Rectangle {
                            height: 46px;
                            border-radius: Radius.md;
                            trow := TouchArea {}
                            background: trow.has-hover ? Theme.c.surface-raised : transparent;
                            animate background { duration: Motion.fast; }
                            HorizontalLayout {
                                padding-left: Space.md;
                                padding-right: Space.sm;
                                spacing: Space.md;
                                VerticalLayout {
                                    alignment: center;
                                    Dot { tint: t.online ? Theme.c.success : Theme.c.muted; }
                                }
                                VerticalLayout {
                                    alignment: center;
                                    horizontal-stretch: 1;
                                    Text {
                                        text: t.name;
                                        color: Theme.c.foreground;
                                        font-weight: Type.medium;
                                        overflow: elide;
                                    }
                                }
                                VerticalLayout {
                                    alignment: center;
                                    Text {
                                        text: t.fp;
                                        color: Theme.c.muted;
                                        font-family: Type.mono;
                                        font-size: Type.caption;
                                        letter-spacing: Type.mono-tracking;
                                    }
                                }
                                // normal: colored status + ghost revoke
                                if root.confirm-revoke-fp != t.fp-full: VerticalLayout {
                                    alignment: center;
                                    Text {
                                        text: t.online ? "connected" : "offline";
                                        color: t.online ? Theme.c.success : Theme.c.muted;
                                        font-size: Type.small;
                                        font-weight: Type.medium;
                                    }
                                }
                                if root.confirm-revoke-fp != t.fp-full: VerticalLayout {
                                    alignment: center;
                                    PillButton {
                                        text: "revoke";
                                        ghost: true;
                                        clicked => { root.confirm-revoke-fp = t.fp-full; }
                                    }
                                }
                                // confirm state
                                if root.confirm-revoke-fp == t.fp-full: VerticalLayout {
                                    alignment: center;
                                    Text {
                                        text: "remove?";
                                        color: Theme.c.muted;
                                        font-size: Type.small;
                                    }
                                }
                                if root.confirm-revoke-fp == t.fp-full: VerticalLayout {
                                    alignment: center;
                                    PillButton {
                                        text: "yes";
                                        danger: true;
                                        clicked => {
                                            root.revoke(t.fp-full);
                                            root.confirm-revoke-fp = "";
                                        }
                                    }
                                }
                                if root.confirm-revoke-fp == t.fp-full: VerticalLayout {
                                    alignment: center;
                                    PillButton {
                                        text: "no";
                                        ghost: true;
                                        clicked => { root.confirm-revoke-fp = ""; }
                                    }
                                }
                            }
                        }
                    }
                }

            }
        }

        // --- footer: theme swatches + device id --------------------------------
        HorizontalLayout {
            spacing: Space.sm;
            VerticalLayout {
                alignment: center;
                Text { text: "theme"; color: Theme.c.muted; font-size: Type.caption; }
            }
            for pal[i] in Theme.palettes: VerticalLayout {
                alignment: center;
                Rectangle {
                    width: 18px;
                    height: 18px;
                    border-radius: self.width / 2;
                    background: pal.accent;
                    border-width: i == Theme.index ? 2px : 0px;
                    border-color: Theme.c.foreground;
                    TouchArea {
                        mouse-cursor: pointer;
                        clicked => { root.set-theme(i); }
                    }
                }
            }
            Rectangle { horizontal-stretch: 1; }
            VerticalLayout {
                alignment: center;
                Text {
                    text: root.fingerprint;
                    color: Theme.c.muted;
                    font-family: Type.mono;
                    font-size: Type.caption;
                    letter-spacing: Type.mono-tracking;
                    overflow: elide;
                }
            }
        }
    }

    // --- settings overlay (a sibling of the root layout so it floats above it) --
    if root.show-settings: Rectangle {
        x: 0px;
        y: 0px;
        width: parent.width;
        height: parent.height;
        background: #000000cc;

        TouchArea { clicked => { root.show-settings = false; } }

        Rectangle {
            width: 320px;
            height: 200px;
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            background: Theme.c.surface;
            border-radius: Radius.lg;
            border-width: 1px;
            border-color: Theme.c.border;

            TouchArea {} // swallows clicks so the panel doesn't close itself

            VerticalLayout {
                padding: Space.xxl;
                spacing: Space.md;
                Text {
                    text: "settings";
                    font-size: Type.heading;
                    font-weight: Type.bold;
                    color: Theme.c.foreground;
                }
                VerticalLayout {
                    spacing: 6px;
                    SectionTitle { text: "interface"; color: Theme.c.accent; }
                    HorizontalLayout {
                        spacing: Space.sm;
                        PillButton { text: "graphical"; primary: true; enabled: false; }
                        PillButton {
                            text: "terminal";
                            clicked => { root.switch-interface(); }
                        }
                    }
                }
                Rectangle { vertical-stretch: 1; }
                PillButton {
                    text: "close";
                    ghost: true;
                    clicked => { root.show-settings = false; }
                }
            }
        }
    }

    // --- layout canvas overlay ---------------------------------------------
    if root.show-layout-canvas: Rectangle {
        x: 0px;
        y: 0px;
        width: parent.width;
        height: parent.height;
        background: #000000cc;

        TouchArea { clicked => { root.show-layout-canvas = false; } }

        LayoutCanvas {
            width: 560px;
            height: 420px;
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            boxes: root.canvas-boxes;
            close => { root.show-layout-canvas = false; }
            geometry-changed(handle, x, y) => { root.update-device-geometry(handle, x, y); }
        }
    }
}
