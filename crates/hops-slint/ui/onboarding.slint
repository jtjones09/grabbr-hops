// hops — first-run "choose your interface" screen. This is the very first
// thing a new user sees when they launch `hops`: two illustrative previews (the
// GUI you're looking at right now, and the terminal alternative) side by side, so
// the choice is concrete rather than a description. The choice is persisted
// (lan_mouse_frontend_core::prefs) and always changeable later from Settings —
// this screen is not a one-way door.

import { Theme, Type, Space, Radius } from "theme.slint";
import { PillButton } from "widgets.slint";
import { GuiPreviewMockup, TuiPreviewMockup } from "previews.slint";

export component OnboardingWindow inherits Window {
    title: "welcome to hops";
    default-font-family: Type.sans;
    default-font-size: Type.body;
    // Fixed-size, non-resizable (see AppWindow's note). Onboarding content is
    // fixed — two interface previews — so no scroll is needed, just lock it.
    preferred-width: 580px;
    preferred-height: 470px;
    min-width: 580px;
    max-width: 580px;
    min-height: 470px;
    max-height: 470px;
    background: Theme.c.background;

    callback choose-gui();
    callback choose-tui();

    VerticalLayout {
        padding: Space.xxl;
        spacing: Space.lg;

        VerticalLayout {
            spacing: 4px;
            Text {
                text: "welcome to hops";
                font-size: Type.title;
                font-weight: Type.bold;
                color: Theme.c.foreground;
            }
            Text {
                text: "choose how you'd like to control your devices — you can switch anytime from Settings";
                font-size: Type.small;
                color: Theme.c.muted;
                wrap: word-wrap;
            }
        }

        HorizontalLayout {
            spacing: Space.lg;

            VerticalLayout {
                horizontal-stretch: 1;
                spacing: Space.md;
                GuiPreviewMockup { height: 130px; }
                VerticalLayout {
                    spacing: 2px;
                    Text {
                        text: "graphical";
                        font-size: Type.heading;
                        font-weight: Type.semibold;
                        color: Theme.c.foreground;
                    }
                    Text {
                        text: "windowed, point-and-click — best on your desktop";
                        font-size: Type.caption;
                        color: Theme.c.muted;
                        wrap: word-wrap;
                    }
                }
                PillButton {
                    text: "choose graphical";
                    primary: true;
                    clicked => { root.choose-gui(); }
                }
            }

            VerticalLayout {
                horizontal-stretch: 1;
                spacing: Space.md;
                TuiPreviewMockup { height: 130px; }
                VerticalLayout {
                    spacing: 2px;
                    Text {
                        text: "terminal";
                        font-size: Type.heading;
                        font-weight: Type.semibold;
                        color: Theme.c.foreground;
                    }
                    Text {
                        text: "keyboard-driven — runs anywhere, great over SSH";
                        font-size: Type.caption;
                        color: Theme.c.muted;
                        wrap: word-wrap;
                    }
                }
                PillButton {
                    text: "choose terminal";
                    primary: true;
                    clicked => { root.choose-tui(); }
                }
            }
        }

        Text {
            text: "hops keeps working in the background either way — this only picks how you view it";
            font-size: Type.caption;
            color: Theme.c.muted;
            horizontal-alignment: center;
        }
    }
}
