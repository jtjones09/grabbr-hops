// grabbr-hop design language — the single source of truth for the GUI.
//
// One token system, rendered identically on macOS / Windows / Linux / Pi (Slint
// draws its own pixels). Encodes the Hotash house style: Space Grotesk + Space
// Mono, restraint (one accent, grayscale rest), tonal elevation (lighter surface
// = higher, no drop shadows in the dark themes). Everything in logical `px` so it
// scales cleanly across HiDPI.

// --- font registration (makes the families available app-wide) ----------------
import "../fonts/SpaceGrotesk-Regular.ttf";
import "../fonts/SpaceGrotesk-Medium.ttf";
import "../fonts/SpaceGrotesk-SemiBold.ttf";
import "../fonts/SpaceGrotesk-Bold.ttf";
import "../fonts/SpaceMono-Regular.ttf";
import "../fonts/SpaceMono-Bold.ttf";

// --- spacing scale (4px base) -------------------------------------------------
export global Space {
    out property <length> xs: 4px;
    out property <length> sm: 8px;
    out property <length> md: 12px;
    out property <length> lg: 16px;
    out property <length> xl: 20px;
    out property <length> xxl: 24px;
    out property <length> xxxl: 32px;
}

// --- corner radii -------------------------------------------------------------
export global Radius {
    out property <length> sm: 6px;   // chips, small buttons
    out property <length> md: 10px;  // rows, cards
    out property <length> lg: 14px;  // window, panels
    out property <length> pill: 999px;
}

// --- typography ---------------------------------------------------------------
export global Type {
    out property <string> sans: "Space Grotesk";
    out property <string> mono: "Space Mono";
    out property <length> caption: 11px;
    out property <length> small: 12px;
    out property <length> body: 14px;
    out property <length> heading: 16px;
    out property <length> title: 22px;
    out property <int> regular: 400;
    out property <int> medium: 500;
    out property <int> semibold: 600;
    out property <int> bold: 700;
    // letter-spacing applied to mono at small sizes (keeps Space Mono legible
    // in dense rows like the fingerprint / addresses)
    out property <length> mono-tracking: 0.4px;
}

// --- motion -------------------------------------------------------------------
export global Motion {
    out property <duration> fast: 120ms;   // hover, press
    out property <duration> base: 200ms;   // list/panel changes
    out property <duration> slow: 320ms;   // overlays (pairing prompt)
}

// --- control sizing -----------------------------------------------------------
// Fixed heights so controls hug + center in a row instead of stretching to the
// cross-axis (Slint stretches an unpinned layout child to fill the row height).
export global Size {
    out property <length> chip: 22px;     // pos / status chips
    out property <length> control: 30px;  // buttons, pill, text field
    out property <length> row: 44px;      // list rows
}

// --- color: semantic taxonomy (mirrors Slint's built-in Palette) --------------
// `color` (not `brush`) so components can derive hover/press/tint states with
// .brighter() / .darker() / .transparentize().
export struct ThemeColors {
    background: color,       // window
    surface: color,         // panels / list backgrounds
    surface-raised: color,  // cards / controls / hover
    foreground: color,      // primary text
    muted: color,           // secondary text / hints
    accent: color,          // the one accent
    on-accent: color,       // text/icons on accent
    selection: color,       // selected row tint
    border: color,          // hairlines / separators
    success: color,
    warn: color,
    error: color,
}

// The available themes as token sets — built-ins AND any user-authored themes
// dropped in ~/.config/lan-mouse/themes/*.toml. Rust is the single source of
// truth for the color DATA (lan-mouse-frontend-core::theme; see that module for
// the schema and how to author your own); Slint only owns how colors are USED.
// Rust sets `palettes` once at startup (and `index` on every pick); `c` resolves
// the active palette. Surfaces step up in luminance for elevation (dark themes)
// instead of shadows.
export global Theme {
    in-out property <int> index: 0;
    in property <[ThemeColors]> palettes: [];
    out property <ThemeColors> c: root.palettes[root.index];
}
