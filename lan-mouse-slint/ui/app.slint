// grabbr-hop Slint GUI — P1 (functional read-only: live status + device + trusted
// lists, themed via the shared palette). Interactivity (add/trust/revoke) and the
// visual polish come next — designed with eyes on the screen.

export struct Palette {
    bg: color,
    fg: color,
    muted: color,
    accent: color,
    success: color,
    warn: color,
    error: color,
}

export struct DeviceRow {
    label: string,
    pos: string,
    state: string,
    dot: color,
}

export struct TrustedRow {
    name: string,
    fp: string,
    status: string,
    dot: color,
}

export component AppWindow inherits Window {
    title: "grabbr-hop";
    preferred-width: 560px;
    preferred-height: 460px;
    min-width: 380px;
    min-height: 300px;

    in property <Palette> palette: {
        bg: #121216, fg: #e8e8ea, muted: #8e8e99, accent: #579bff,
        success: #44c468, warn: #e7b84b, error: #f25d5d,
    };
    in property <bool> connected: false;
    in property <string> capture: "—";
    in property <string> emulation: "—";
    in property <string> port: "—";
    in property <string> fingerprint: "—";
    in property <[DeviceRow]> devices: [];
    in property <[TrustedRow]> trusted: [];

    background: palette.bg;

    VerticalLayout {
        padding: 18px;
        spacing: 12px;

        Text {
            text: "grabbr-hop";
            font-size: 22px;
            font-weight: 800;
            color: palette.accent;
        }

        HorizontalLayout {
            spacing: 20px;
            Text {
                text: root.connected ? "● connected" : "○ connecting…";
                color: root.connected ? palette.success : palette.warn;
            }
            Text { text: "capture: " + root.capture; color: palette.fg; }
            Text { text: "emulation: " + root.emulation; color: palette.fg; }
            Text { text: "port: " + root.port; color: palette.muted; }
        }

        Rectangle { height: 1px; background: palette.muted; }

        Text { text: "devices (cross to)"; font-weight: 700; color: palette.accent; }
        if root.devices.length == 0: Text {
            text: "none — this device only receives";
            color: palette.muted;
        }
        for d in root.devices: HorizontalLayout {
            spacing: 8px;
            Text { text: "●"; color: d.dot; }
            Text { text: d.label; color: palette.fg; }
            Text { text: d.pos; color: palette.accent; }
            Text { text: d.state; color: palette.muted; }
        }

        Rectangle { height: 1px; background: palette.muted; }

        Text { text: "trusted devices"; font-weight: 700; color: palette.accent; }
        if root.trusted.length == 0: Text {
            text: "no trusted devices";
            color: palette.muted;
        }
        for t in root.trusted: HorizontalLayout {
            spacing: 8px;
            Text { text: "●"; color: t.dot; }
            Text { text: t.name; color: palette.fg; }
            Text { text: t.fp; color: palette.muted; }
            Text { text: t.status; color: t.dot; }
        }

        Rectangle { } // spacer pushes the fingerprint to the bottom

        Text {
            text: "this device: " + root.fingerprint;
            color: palette.muted;
            font-size: 10px;
            wrap: word-wrap;
        }
    }
}
