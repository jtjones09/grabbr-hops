// grabbr-hop — the GUI surface. Composes the design tokens (theme.slint) and the
// atoms (widgets.slint) into the control panel: live status, the outgoing-device
// list, and the trusted-peer list, with the core interactions wired — approve a
// Windows→Mac pairing, re-enable input, toggle a device, revoke trust (confirm-
// gated). Rust sets `Theme.index`, the status fields, the two lists, and the live
// `pairing-fp`; the callbacks below send `FrontendRequest`s back through Rust.

import { Theme, Type, Space, Radius, Motion } from "theme.slint";
import { Card, Separator, Dot, Chip, StatChip, SectionTitle, PillButton, TextField } from "widgets.slint";

// re-export so Rust can select the active palette via `ui.global::<Theme>()`
export { Theme }

export struct DeviceRow {
    handle: string,  // ClientHandle (u64 as text — Slint int is only i32)
    label: string,   // "[handle] hostname:port"
    pos: string,     // "left" / "right" / …
    active: bool,    // capture is routed to this device
    alive: bool,     // device is reachable
}

export struct TrustedRow {
    name: string,
    fp: string,      // short fingerprint (display)
    fp-full: string, // full fingerprint (for requests)
    online: bool,
}

export component AppWindow inherits Window {
    title: "grabbr-hop";
    default-font-family: Type.sans;
    default-font-size: Type.body;
    preferred-width: 600px;
    preferred-height: 540px;
    min-width: 440px;
    min-height: 400px;
    background: Theme.c.background;

    in property <bool> connected: false;
    in property <string> capture: "—";
    in property <string> emulation: "—";
    in property <string> port: "—";
    in property <string> fingerprint: "—";
    in property <[DeviceRow]> devices: [];
    in property <[TrustedRow]> trusted: [];
    // full fingerprint of a peer awaiting pairing approval ("" = none). Rust
    // sets this only while the request is live (freshness + snooze applied).
    in property <string> pairing-fp: "";

    // UI-local: which trusted row is mid-revoke-confirm ("" = none)
    property <string> confirm-revoke-fp: "";

    callback enable-input();
    callback activate-device(string /* handle */, bool /* active */);
    callback revoke(string /* full fingerprint */);
    callback approve-pairing(string /* name */, string /* full fingerprint */);
    callback deny-pairing(string /* full fingerprint */);

    VerticalLayout {
        padding: Space.xxl;
        spacing: Space.lg;

        // --- header: wordmark + connection pill ---------------------------------
        HorizontalLayout {
            alignment: space-between;
            VerticalLayout {
                spacing: 2px;
                vertical-stretch: 0;
                Text {
                    text: "grabbr-hop";
                    font-size: Type.title;
                    font-weight: Type.bold;
                    color: Theme.c.foreground;
                }
                Text {
                    text: "software KVM";
                    font-family: Type.mono;
                    font-size: Type.caption;
                    letter-spacing: Type.mono-tracking;
                    color: Theme.c.muted;
                }
            }
            Rectangle {
                horizontal-stretch: 0;
                vertical-stretch: 0;
                background: root.connected
                    ? Theme.c.success.transparentize(0.86)
                    : Theme.c.warn.transparentize(0.86);
                border-radius: Radius.pill;
                border-width: 1px;
                border-color: root.connected
                    ? Theme.c.success.transparentize(0.6)
                    : Theme.c.warn.transparentize(0.6);
                HorizontalLayout {
                    padding-left: Space.md;
                    padding-right: Space.md;
                    padding-top: 6px;
                    padding-bottom: 6px;
                    spacing: Space.sm;
                    Dot { tint: root.connected ? Theme.c.success : Theme.c.warn; }
                    Text {
                        text: root.connected ? "connected" : "connecting";
                        color: root.connected ? Theme.c.success : Theme.c.warn;
                        font-size: Type.small;
                        font-weight: Type.semibold;
                    }
                }
            }
        }

        // --- pairing request banner (Windows wants to connect to this Mac) ------
        if root.pairing-fp != "": Rectangle {
            vertical-stretch: 0;
            background: Theme.c.accent.transparentize(0.88);
            border-radius: Radius.lg;
            border-width: 1px;
            border-color: Theme.c.accent.transparentize(0.5);
            VerticalLayout {
                padding: Space.md;
                spacing: Space.sm;
                Text {
                    text: "pairing request";
                    color: Theme.c.accent;
                    font-size: Type.small;
                    font-weight: Type.semibold;
                }
                Text {
                    text: root.pairing-fp;
                    color: Theme.c.muted;
                    font-family: Type.mono;
                    font-size: Type.caption;
                    letter-spacing: Type.mono-tracking;
                    overflow: elide;
                }
                HorizontalLayout {
                    spacing: Space.sm;
                    name := TextField {
                        placeholder: "name this device";
                        horizontal-stretch: 1;
                        accepted => {
                            root.approve-pairing(self.text, root.pairing-fp);
                            self.text = "";
                        }
                    }
                    PillButton {
                        text: "approve";
                        primary: true;
                        clicked => {
                            root.approve-pairing(name.text, root.pairing-fp);
                            name.text = "";
                        }
                    }
                    PillButton {
                        text: "deny";
                        clicked => { root.deny-pairing(root.pairing-fp); }
                    }
                }
            }
        }

        // --- status strip -------------------------------------------------------
        HorizontalLayout {
            spacing: Space.sm;
            alignment: start;
            StatChip {
                label: "capture";
                value: root.capture;
                value-color: root.capture == "enabled" ? Theme.c.success : Theme.c.muted;
            }
            StatChip {
                label: "emulation";
                value: root.emulation;
                value-color: root.emulation == "enabled" ? Theme.c.success : Theme.c.muted;
            }
            StatChip {
                label: "port";
                value: root.port;
            }
            if root.capture != "enabled" || root.emulation != "enabled": PillButton {
                text: "enable input";
                primary: true;
                clicked => { root.enable-input(); }
            }
        }

        // --- devices ------------------------------------------------------------
        SectionTitle { text: "DEVICES"; }
        Card {
            vertical-stretch: 0;
            VerticalLayout {
                padding: Space.sm;
                spacing: 2px;
                if root.devices.length == 0: HorizontalLayout {
                    padding: Space.sm;
                    Text {
                        text: "no outgoing devices — this Mac only receives";
                        color: Theme.c.muted;
                        font-size: Type.small;
                    }
                }
                for d in root.devices: Rectangle {
                    height: 46px;
                    border-radius: Radius.md;
                    drow := TouchArea {}
                    background: drow.has-hover ? Theme.c.surface-raised : transparent;
                    animate background { duration: Motion.fast; }
                    HorizontalLayout {
                        padding-left: Space.md;
                        padding-right: Space.md;
                        spacing: Space.md;
                        Dot {
                            tint: d.alive
                                ? Theme.c.success
                                : (d.active ? Theme.c.warn : Theme.c.muted);
                        }
                        Text {
                            text: d.label;
                            color: Theme.c.foreground;
                            font-weight: Type.medium;
                            overflow: elide;
                            horizontal-stretch: 1;
                            vertical-alignment: center;
                        }
                        Chip {
                            text: d.pos;
                            text-color: Theme.c.accent;
                            fill: Theme.c.accent.transparentize(0.85);
                        }
                        PillButton {
                            text: d.active ? "on" : "off";
                            primary: d.active;
                            clicked => { root.activate-device(d.handle, !d.active); }
                        }
                    }
                }
            }
        }

        // --- trusted peers ------------------------------------------------------
        SectionTitle { text: "TRUSTED"; }
        Card {
            vertical-stretch: 0;
            VerticalLayout {
                padding: Space.sm;
                spacing: 2px;
                if root.trusted.length == 0: HorizontalLayout {
                    padding: Space.sm;
                    Text {
                        text: "no trusted devices yet";
                        color: Theme.c.muted;
                        font-size: Type.small;
                    }
                }
                for t in root.trusted: Rectangle {
                    height: 50px;
                    border-radius: Radius.md;
                    trow := TouchArea {}
                    background: trow.has-hover ? Theme.c.surface-raised : transparent;
                    animate background { duration: Motion.fast; }
                    HorizontalLayout {
                        padding-left: Space.md;
                        padding-right: Space.md;
                        spacing: Space.md;
                        Dot { tint: t.online ? Theme.c.success : Theme.c.muted; }
                        VerticalLayout {
                            alignment: center;
                            spacing: 1px;
                            horizontal-stretch: 1;
                            Text {
                                text: t.name;
                                color: Theme.c.foreground;
                                font-weight: Type.medium;
                                overflow: elide;
                            }
                            Text {
                                text: t.fp;
                                color: Theme.c.muted;
                                font-family: Type.mono;
                                font-size: Type.caption;
                                letter-spacing: Type.mono-tracking;
                                overflow: elide;
                            }
                        }
                        // normal trailing controls
                        if root.confirm-revoke-fp != t.fp-full: Chip {
                            text: t.online ? "connected" : "offline";
                            text-color: t.online ? Theme.c.success : Theme.c.muted;
                            fill: Theme.c.surface-raised;
                        }
                        if root.confirm-revoke-fp != t.fp-full: PillButton {
                            text: "revoke";
                            clicked => { root.confirm-revoke-fp = t.fp-full; }
                        }
                        // confirm state
                        if root.confirm-revoke-fp == t.fp-full: Text {
                            text: "remove trust?";
                            color: Theme.c.muted;
                            font-size: Type.caption;
                            vertical-alignment: center;
                        }
                        if root.confirm-revoke-fp == t.fp-full: PillButton {
                            text: "yes";
                            danger: true;
                            clicked => {
                                root.revoke(t.fp-full);
                                root.confirm-revoke-fp = "";
                            }
                        }
                        if root.confirm-revoke-fp == t.fp-full: PillButton {
                            text: "no";
                            clicked => { root.confirm-revoke-fp = ""; }
                        }
                    }
                }
            }
        }

        Rectangle { vertical-stretch: 1; } // pushes the footer to the bottom

        // --- footer: this device's id ------------------------------------------
        HorizontalLayout {
            spacing: Space.sm;
            Text {
                text: "device id";
                color: Theme.c.muted;
                font-size: Type.caption;
                vertical-alignment: center;
            }
            Text {
                text: root.fingerprint;
                color: Theme.c.muted;
                font-family: Type.mono;
                font-size: Type.caption;
                letter-spacing: Type.mono-tracking;
                overflow: elide;
                horizontal-stretch: 1;
                vertical-alignment: center;
            }
        }
    }
}
