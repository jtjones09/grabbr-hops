// grabbr-hop reusable UI atoms — built from the design tokens (theme.slint), so
// every control is themed and consistent. Kept presentational: no app state, just
// inputs + a `clicked` callback where relevant. Composition lives in app.slint.

import { Theme, Type, Space, Radius, Motion, Size } from "theme.slint";

// A rounded surface panel. Tonal elevation: surface sits above the window bg.
export component Card inherits Rectangle {
    background: Theme.c.surface;
    border-radius: Radius.lg;
    border-width: 1px;
    border-color: Theme.c.border;
}

// Hairline separator.
export component Separator inherits Rectangle {
    height: 1px;
    background: Theme.c.border;
}

// Small status dot.
export component Dot inherits Rectangle {
    in property <color> tint: Theme.c.muted;
    width: 8px;
    height: 8px;
    border-radius: self.width / 2;
    background: root.tint;
}

// A compact rounded label (position, state, …). Hugs its text; fixed height so
// it centers in a row instead of stretching to fill it.
export component Chip inherits Rectangle {
    in property <string> text;
    in property <color> text-color: Theme.c.muted;
    in property <color> fill: Theme.c.surface-raised;
    background: root.fill;
    border-radius: Radius.sm;
    horizontal-stretch: 0;
    height: Size.chip;
    HorizontalLayout {
        padding-left: Space.sm;
        padding-right: Space.sm;
        alignment: center;
        Text {
            text: root.text;
            color: root.text-color;
            font-size: Type.caption;
            font-weight: Type.semibold;
            vertical-alignment: center;
        }
    }
}

// Labeled stat ("capture · on"). Label in sans, value in mono with tracking.
export component StatChip inherits Rectangle {
    in property <string> label;
    in property <string> value;
    in property <color> value-color: Theme.c.foreground;
    background: Theme.c.surface;
    border-radius: Radius.sm;
    border-width: 1px;
    border-color: Theme.c.border;
    horizontal-stretch: 0;
    height: Size.control;
    HorizontalLayout {
        padding-left: Space.md;
        padding-right: Space.md;
        spacing: 6px;
        alignment: center;
        Text {
            text: root.label;
            color: Theme.c.muted;
            font-size: Type.caption;
            vertical-alignment: center;
        }
        Text {
            text: root.value;
            color: root.value-color;
            font-family: Type.mono;
            font-size: Type.caption;
            font-weight: Type.bold;
            letter-spacing: Type.mono-tracking;
            vertical-alignment: center;
        }
    }
}

// Section eyebrow ("DEVICES"). Pass uppercase text; tracking gives the premium feel.
export component SectionTitle inherits Text {
    font-size: Type.small;
    font-weight: Type.semibold;
    color: Theme.c.muted;
    letter-spacing: 0.8px;
}

// A pill button. `primary` = filled accent, `danger` = filled error,
// `ghost` = chromeless (muted text, lights up on hover), else outline.
export component PillButton inherits Rectangle {
    in property <string> text;
    in property <bool> primary: false;
    in property <bool> danger: false;
    in property <bool> ghost: false;
    in property <bool> enabled: true;
    callback clicked;

    property <color> base: root.danger
        ? Theme.c.error
        : (root.primary ? Theme.c.accent : Theme.c.surface-raised);
    property <bool> filled: root.primary || root.danger;

    horizontal-stretch: 0;
    height: Size.control;
    border-radius: Radius.sm;
    border-width: (root.filled || root.ghost) ? 0px : 1px;
    border-color: Theme.c.border;
    opacity: root.enabled ? 1.0 : 0.45;
    background: root.ghost
        ? (ta.pressed
            ? Theme.c.surface-raised.darker(0.1)
            : (ta.has-hover ? Theme.c.surface-raised : transparent))
        : (!root.enabled
            ? root.base
            : (ta.pressed ? root.base.darker(0.12) : (ta.has-hover ? root.base.brighter(0.12) : root.base)));
    animate background { duration: Motion.fast; }

    HorizontalLayout {
        padding-left: Space.md;
        padding-right: Space.md;
        alignment: center;
        Text {
            text: root.text;
            color: root.filled
                ? Theme.c.on-accent
                : (root.ghost && !ta.has-hover ? Theme.c.muted : Theme.c.foreground);
            font-size: Type.small;
            font-weight: Type.semibold;
            vertical-alignment: center;
        }
    }

    ta := TouchArea {
        enabled: root.enabled;
        mouse-cursor: pointer;
        clicked => { root.clicked(); }
    }
}

// An iOS-style toggle switch. Track lights green when on; the knob slides.
export component Toggle inherits Rectangle {
    in property <bool> checked;
    callback toggled(bool);
    width: 42px;
    height: 24px;
    horizontal-stretch: 0;
    border-radius: self.height / 2;
    background: root.checked ? Theme.c.success : Theme.c.surface-raised;
    border-width: root.checked ? 0px : 1px;
    border-color: Theme.c.border;
    animate background { duration: Motion.fast; }

    knob := Rectangle {
        width: 18px;
        height: 18px;
        border-radius: self.width / 2;
        background: #ffffff;
        y: (parent.height - self.height) / 2;
        x: root.checked ? parent.width - self.width - 3px : 3px;
        animate x { duration: Motion.fast; }
    }

    TouchArea {
        mouse-cursor: pointer;
        clicked => { root.toggled(!root.checked); }
    }
}

// A single-line text field built on the low-level TextInput so it matches the
// design tokens (no stock-widget chrome). Accent border on focus, themed caret
// selection, muted placeholder that hides once focused.
export component TextField inherits Rectangle {
    in property <string> placeholder;
    in-out property <string> text <=> ti.text;
    callback accepted <=> ti.accepted;
    forward-focus: ti;
    height: Size.control;
    background: Theme.c.surface-raised;
    border-radius: Radius.sm;
    border-width: 1px;
    border-color: ti.has-focus ? Theme.c.accent : Theme.c.border;
    animate border-color { duration: Motion.fast; }

    Text {
        x: Space.sm;
        height: 100%;
        vertical-alignment: center;
        text: root.placeholder;
        color: Theme.c.muted;
        font-size: Type.small;
        visible: ti.text == "" && !ti.has-focus;
    }
    ti := TextInput {
        x: Space.sm;
        width: parent.width - 2 * Space.sm;
        height: 100%;
        vertical-alignment: center;
        color: Theme.c.foreground;
        font-size: Type.small;
        single-line: true;
        selection-background-color: Theme.c.accent;
        selection-foreground-color: Theme.c.on-accent;
    }
}
